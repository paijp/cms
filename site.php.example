<?php
/**
 * サイト固有設定のサンプル
 *
 * このファイルを site.php にコピーして書き換え、data/site.php として置く。
 * （既定パス: /var/www/kimoken-cms/data/site.php ※環境変数 CMS_CONFIG で変更可）
 * data/ ディレクトリ以下だけを丸ごとバックアップすれば、記事本体と設定が
 * 両方保存できる。site.php 本体は公開リポジトリにコミットしないこと。
 */
return [
    // サイト名（トップページ・管理画面のタイトルとロゴに表示）
    'site_name' => 'サンプル株式会社',
    // 任意: ロゴ表示用のHTML。指定すると公開ページのロゴ部分に <span class="brand-accent">
    // などを使ってブランドの一部を強調表示できる（未設定なら site_name をそのまま表示）
    // 'site_name_html' => '<span class="brand-accent">サンプル</span>株式会社',

    // フッターの表記
    'copyright' => '© 2026 サンプル株式会社',

    // ジャンル（タブ）。先頭がトップページの初期表示タブになる
    'genres' => [
        ['key' => 'news', 'label' => 'お知らせ'],
        ['key' => 'faq',  'label' => 'よくある質問'],
    ],

    // 公開版の記事データ置き場（ドキュメントルート外に置くこと）
    'data_dir'    => '/var/www/example-cms/data/articles/',

    // 下書きの記事データ置き場
    'drafts_dir'  => '/var/www/example-cms/data/drafts/',

    // 管理者トークンファイル（openssl rand -hex 32 > admin_token で生成）
    'token_file'  => '/var/www/example-cms/admin_token',

    // ログインセッションの保存先
    'session_dir' => '/var/www/example-cms/sessions/',

    // アップロード画像の保存先（バックアップ対象外の場所を推奨）
    'upload_dir'  => '/var/www/example-cms/uploads/',
    // アップロード画像を配信する公開URL（nginx alias または docroot 下の symlink で紐付け）
    // 例: nginx で   location /uploads/ { alias /var/www/example-cms/uploads/; }
    //     もしくは   ln -s /var/www/example-cms/uploads /var/www/html/uploads
    'upload_url'  => '/uploads/',
];
